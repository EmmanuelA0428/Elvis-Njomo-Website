# Public (safe in Vite — exposed to the browser)
VITE_SANITY_PROJECT_ID=mokhd6fe
VITE_SANITY_DATASET=production

# Never commit. Create at https://www.sanity.io/manage → project → API → Tokens (Editor)
# Used only for: npm run migrate:sanity (loaded via dotenv from this file)
SANITY_API_WRITE_TOKEN=

# Optional: ms pause between image uploads during migrate (default 120) — can raise to 200 if you still see 502s
# MIGRATE_UPLOAD_GAP_MS=200
